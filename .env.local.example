# ============================================
# LinkedIn Marketing Agent MVP — Environment Variables
# ============================================
# Fill in each value as you set up each service.
# NEVER commit this file to git. Add .env* to your .gitignore.
# ============================================


# ------------------------------------------
# SUPABASE (supabase.com → Project Settings → API)
# ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=              # e.g. https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Settings → API → anon / public key
SUPABASE_SERVICE_ROLE_KEY=             # Settings → API → service_role key (SERVER-SIDE ONLY — never expose to browser)


# ------------------------------------------
# DATABASE (supabase.com → Project Settings → Database)
# ------------------------------------------
DATABASE_URL=                         # Settings → Database → Connection String → URI (with your password filled in)
DIRECT_URL=                            # Settings → Database → Connection String → Direct Connection URI


# ------------------------------------------
# ANTHROPIC — AI Generation (console.anthropic.com → API Keys)
# ------------------------------------------
ANTHROPIC_API_KEY=                     # Primary LLM provider — powers all post generation and voice analysis


# ------------------------------------------
# GOOGLE OAUTH (console.cloud.google.com → Credentials)
# ------------------------------------------
# Note: These are also pasted into Supabase Dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=                      # OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=                  # OAuth 2.0 Client Secret


# ------------------------------------------
# APP CONFIG
# ------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Change to your production domain when deploying (e.g. https://app.yourproduct.com)


# ------------------------------------------
# OPTIONAL — Add these when needed
# ------------------------------------------
# OPENAI_API_KEY=                      # Backup LLM provider (GPT-4o-mini for cheap analysis tasks)
# DEEPGRAM_API_KEY=                    # V2 — for transcribing uploaded audio/call recordings
# RESEND_API_KEY=                      # For transactional emails (welcome, weekly reports, etc.)
